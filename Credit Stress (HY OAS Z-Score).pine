//@version=6
indicator("Credit Stress (HY OAS Z-Score)", shorttitle="CreditStrs", overlay=false)

hy_spread = request.security("FRED:BAMLH0A0HYM2", "D", close)
recession = request.security("FRED:USREC", "1M", close)

length = input.int(252, title="Z-Score Lookback (trading days, ~1yr)")

hy_mean = ta.sma(hy_spread, length)
hy_std = ta.stdev(hy_spread, length)
hy_z = (hy_spread - hy_mean) / hy_std

plot(hy_z, title="HY OAS Z-Score", color=color.new(#00BFFF, 0), linewidth=2)
hline(0, title="Neutral", color=color.gray, linestyle=hline.style_dashed)

// 壓力警戒帶 (紅):z-score超過1.5代表利差顯著擴大,信用市場緊張
upper_stress = hline(3, title="Extreme Stress Upper", color=color.new(#FF3D00, 70), linestyle=hline.style_dotted)
mid_stress = hline(1.5, title="Stress Threshold", color=color.new(#FF3D00, 70), linestyle=hline.style_dotted)
fill(upper_stress, mid_stress, color=color.new(#FF3D00, 55), title="Stress Zone")

// 自滿/寬鬆帶 (綠):z-score低於-1代表利差異常收窄
lower_calm = hline(-1, title="Complacency Threshold", color=color.new(#00E676, 70), linestyle=hline.style_dotted)
bottom_calm = hline(-2.5, title="Extreme Complacency", color=color.new(#00E676, 70), linestyle=hline.style_dotted)
fill(lower_calm, bottom_calm, color=color.new(#00E676, 55), title="Complacency Zone")

bgcolor(recession == 1 ? color.new(color.gray, 80) : na, title="US Recession")

var table legend = table.new(position.top_right, 2, 2, border_width=1)
if barstate.islast
    table.cell(legend, 0, 0, "", bgcolor=color.new(#FF3D00, 40), width=1, height=1)
    table.cell(legend, 1, 0, "Stress", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
    table.cell(legend, 0, 1, "", bgcolor=color.new(#00E676, 40), width=1, height=1)
    table.cell(legend, 1, 1, "Complacency", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)